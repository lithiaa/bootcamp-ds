{
  "name": "selenium-mocha-indra",
  "version": "1.0.0",
  "description": "Selenium WebDriver tests using Mocha framework",

  "scripts": {
    "test": "mocha test --recursive --timeout 60000",
    "test-mochawesome": "mocha test --recursive --timeout 60000 --reporter mochawesome",
    "test-html-reporter": "mocha test --recursive --timeout 60000 --reporter mocha-simple-html-reporter --reporter-options output=report.html"
  },
  "dependencies": {
    "selenium-webdriver": "4.17.0"
  },
  "devDependencies": {
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.3",
    "mocha-simple-html-reporter": "^2.0.0"
  }
}
